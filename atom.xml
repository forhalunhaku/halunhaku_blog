&lt;/blockquote&gt;
&lt;p&gt;&lt;a href=&quot;https://github.com/forhalunhaku/creep_cal&quot;&gt;&lt;img src=&quot;https://img.shields.io/github/stars/forhalunhaku/creep_cal?style=social&quot; alt=&quot;GitHub stars&quot;&gt;&lt;/a&gt;&lt;br&gt;&lt;a href=&quot;https://creep.halunhaku.top/&quot;&gt;&lt;img src=&quot;https://img.shields.io/badge/%E5%9C%A8%E7%BA%BF%E4%BD%93%E9%AA%8C-creep.halunhaku.top-brightgreen&quot; alt=&quot;在线体验&quot;&gt;&lt;/a&gt;&lt;/p&gt;
